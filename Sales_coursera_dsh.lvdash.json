{
  "datasets": [
    {
      "name": "45fea744",
      "displayName": "quantity_by_countries",
      "queryLines": [
        "-- quantity by countries \r\n",
        "select sum(QUANTITY) as qnt_sum, round(sum(TOTAL_ORDER)) as total_sales, ORDER_COUNTRY\r\n",
        "from workspace.supplychaindb.orders_gold \r\n",
        "where order_status != 'Cancelled' \r\n",
        "group by ORDER_COUNTRY\r\n",
        "order by qnt_sum desc"
      ],
      "catalog": "workspace",
      "schema": "supplychaindb"
    },
    {
      "name": "3307cd9b",
      "displayName": "sales_by_division",
      "queryLines": [
        "-- total sales by categories division\r\n",
        "select sum(QUANTITY) as qnt_sum, round(sum(TOTAL_ORDER)) as total_sales, CATEGORY\r\n",
        "from workspace.supplychaindb.orders_gold \r\n",
        "where order_status != 'Cancelled' \r\n",
        "group by CATEGORY\r\n",
        "order by total_sales desc\r\n"
      ]
    },
    {
      "name": "78adacbb",
      "displayName": "top_5_brands",
      "queryLines": [
        "-- top 5 popular brands\r\n",
        "select sum(QUANTITY) as qnt_sum, round(sum(TOTAL_ORDER)) as total_sales, BRAND\r\n",
        "from workspace.supplychaindb.orders_gold \r\n",
        "where order_status != 'Cancelled' \r\n",
        "group by brand\r\n",
        "order by qnt_sum desc\r\n",
        "limit 5\r\n",
        ";"
      ]
    },
    {
      "name": "5d352477",
      "displayName": "qnt_by_month",
      "queryLines": [
        "select DATE_TRUNC(\"month\", ORDER_DATE) as month_od, sum(QUANTITY) as sum_qnt --, BRAND, ORDER_COUNTRY\r\n",
        "from workspace.supplychaindb.orders_gold \r\n",
        "where order_status != 'Cancelled'\r\n",
        "group by month_od \r\n",
        "-- group by BRAND, ORDER_COUNTRY, month_od\r\n",
        "order by month_od"
      ]
    },
    {
      "name": "2dc85a77",
      "displayName": "qty_left_stock",
      "queryLines": [
        "with qty_sold as(\r\n",
        "select og.BRAND, og.COLOR, og.PRODUCT_NAME, og.SIZE, SUM(og.QUANTITY) AS QTY_SOLD, \r\n",
        "(i.STOCK-qty_sold) AS QTY_LEFT_STOCK\r\n",
        "from workspace.supplychaindb.orders_gold as og\r\n",
        "inner join workspace.supplychaindb.inventory as i\r\n",
        "ON og.BRAND = i.BRAND\r\n",
        "AND og.PRODUCT_NAME = i.PRODUCT_NAME\r\n",
        "AND og.COLOR = i.COLOR\r\n",
        "AND og.SIZE = i.SIZE     \r\n",
        "WHERE ORDER_STATUS != 'Cancelled' \r\n",
        "GROUP BY og.BRAND, og.COLOR, og.PRODUCT_NAME, og.SIZE, i.STOCK\r\n",
        "order by QTY_LEFT_STOCK asc)\r\n",
        "\r\n",
        "select * from qty_sold\r\n",
        "where qty_left_stock < 20\r\n",
        ";"
      ]
    }
  ],
